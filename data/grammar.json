  "topics": [
    {
      "id": "001",
      "title": "Be 動詞 (am / is / are)",
      "emoji": "🪢",
      "category": "動詞",
      "level": "G6",
      "rule": "Be 動詞用來連接「誰」和「狀態 / 身份」。三個變化:I → am、he/she/it/單數 → is、you/we/they/複數 → are。",
      "examples": [
        {
          "en": "I am a student.",
          "zh": "我是學生。"
        },
        {
          "en": "She is happy.",
          "zh": "她很開心。"
        },
        {
          "en": "They are my friends.",
          "zh": "他們是我的朋友。"
        }
      ],
      "quiz": [
        {
          "q": "I ___ ten years old.",
          "options": [
            "am",
            "is",
            "are"
          ],
          "answer": 0
        },
        {
          "q": "She ___ my teacher.",
          "options": [
            "am",
            "is",
            "are"
          ],
          "answer": 1
        },
        {
          "q": "We ___ in the same class.",
          "options": [
            "am",
            "is",
            "are"
          ],
          "answer": 2
        }
      ]
    },
    {
      "id": "002",
      "title": "一般動詞單數加 -s / -es",
      "emoji": "➕",
      "category": "動詞",
      "level": "G6",
      "rule": "主詞是 he / she / it 或單數時,動詞要加 -s。字尾是 s/sh/ch/x/o → 加 -es。字尾是子音+y → 改 -ies。",
      "examples": [
        {
          "en": "He plays soccer.",
          "zh": "他踢足球。"
        },
        {
          "en": "She watches TV.",
          "zh": "她看電視。"
        },
        {
          "en": "The baby cries.",
          "zh": "嬰兒哭了。"
        }
      ],
      "quiz": [
        {
          "q": "He ___ to school every day.",
          "options": [
            "go",
            "goes",
            "going"
          ],
          "answer": 1
        },
        {
          "q": "She ___ her homework.",
          "options": [
            "do",
            "does",
            "doing"
          ],
          "answer": 1
        },
        {
          "q": "My dog ___ a lot.",
          "options": [
            "bark",
            "barks",
            "barking"
          ],
          "answer": 1
        }
      ]
    },
    {
      "id": "003",
      "title": "Do / Does 問句與否定",
      "emoji": "❓",
      "category": "句型",
      "level": "G6",
      "rule": "問題開頭用 Do(I/you/we/they)或 Does(he/she/it)。否定要用 don't / doesn't。原本動詞變回原型(不加 -s)。",
      "examples": [
        {
          "en": "Do you like ice cream?",
          "zh": "你喜歡冰淇淋嗎?"
        },
        {
          "en": "Does she play piano?",
          "zh": "她彈鋼琴嗎?"
        },
        {
          "en": "He doesn't eat meat.",
          "zh": "他不吃肉。"
        }
      ],
      "quiz": [
        {
          "q": "___ you have a pen?",
          "options": [
            "Do",
            "Does",
            "Are"
          ],
          "answer": 0
        },
        {
          "q": "___ she like cats?",
          "options": [
            "Do",
            "Does",
            "Is"
          ],
          "answer": 1
        },
        {
          "q": "He ___ play basketball.",
          "options": [
            "don't",
            "doesn't",
            "isn't"
          ],
          "answer": 1
        }
      ]
    },
    {
      "id": "004",
      "title": "過去式:規則動詞 -ed",
      "emoji": "⏪",
      "category": "動詞",
      "level": "G7",
      "rule": "規則動詞過去式加 -ed。字尾 e → 只加 d。字尾子音+y → 改 -ied。短母音+子音 → 重複末子音再加 -ed(如 stop → stopped)。",
      "examples": [
        {
          "en": "I played basketball yesterday.",
          "zh": "我昨天打了籃球。"
        },
        {
          "en": "She studied hard.",
          "zh": "她很努力讀書。"
        },
        {
          "en": "We stopped at the red light.",
          "zh": "我們在紅燈停下來。"
        }
      ],
      "quiz": [
        {
          "q": "He ___ TV last night.",
          "options": [
            "watch",
            "watched",
            "watches"
          ],
          "answer": 1
        },
        {
          "q": "I ___ to my mom.",
          "options": [
            "talk",
            "talked",
            "talking"
          ],
          "answer": 1
        },
        {
          "q": "They ___ the race.",
          "options": [
            "win",
            "won",
            "winning"
          ],
          "answer": 1
        }
      ]
    },
    {
      "id": "005",
      "title": "過去式:不規則動詞",
      "emoji": "⚡",
      "category": "動詞",
      "level": "G7",
      "rule": "有些動詞過去式不照規則:go→went、have→had、see→saw、do→did、eat→ate、come→came、make→made、take→took、get→got、give→gave。要背熟。",
      "examples": [
        {
          "en": "I went to the park.",
          "zh": "我去了公園。"
        },
        {
          "en": "She had breakfast.",
          "zh": "她吃了早餐。"
        },
        {
          "en": "We saw a movie.",
          "zh": "我們看了一部電影。"
        }
      ],
      "quiz": [
        {
          "q": "I ___ to school by bus yesterday.",
          "options": [
            "go",
            "goed",
            "went"
          ],
          "answer": 2
        },
        {
          "q": "She ___ dinner at 7.",
          "options": [
            "had",
            "haved",
            "has"
          ],
          "answer": 0
        },
        {
          "q": "They ___ a big cake.",
          "options": [
            "maked",
            "made",
            "makes"
          ],
          "answer": 1
        }
      ]
    },
    {
      "id": "006",
      "title": "現在進行式 (be + Ving)",
      "emoji": "🏃",
      "category": "動詞",
      "level": "G7",
      "rule": "表示「現在正在做」。用 am/is/are + 動詞 ing。字尾 e 去掉再加 ing(make→making)。短母音+子音重複再加 ing(run→running)。",
      "examples": [
        {
          "en": "I am reading a book.",
          "zh": "我正在讀一本書。"
        },
        {
          "en": "She is cooking dinner.",
          "zh": "她正在煮晚餐。"
        },
        {
          "en": "They are playing outside.",
          "zh": "他們正在外面玩。"
        }
      ],
      "quiz": [
        {
          "q": "Look! He ___ swimming.",
          "options": [
            "is",
            "are",
            "am"
          ],
          "answer": 0
        },
        {
          "q": "I am ___ my homework.",
          "options": [
            "do",
            "doing",
            "does"
          ],
          "answer": 1
        },
        {
          "q": "The dog ___ running fast.",

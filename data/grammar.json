    {
      "id": "012",
      "title": "可數 vs 不可數 / some / any",
      "emoji": "🍎",
      "category": "名詞",
      "level": "G7",
      "rule": "可數名詞有單複數(an apple, three apples)。不可數名詞沒複數(water, sugar, money)。some 用肯定,any 用問句和否定。",
      "examples": [
        {
          "en": "I want some water.",
          "zh": "我想要一些水。"
        },
        {
          "en": "Do you have any questions?",
          "zh": "你有任何問題嗎?"
        },
        {
          "en": "There isn't any milk.",
          "zh": "沒有牛奶了。"
        }
      ],
      "quiz": [
        {
          "q": "I have ___ friends here.",
          "options": [
            "some",
            "any",
            "a"
          ],
          "answer": 0
        },
        {
          "q": "Do you want ___ tea?",
          "options": [
            "some",
            "any",
            "a"
          ],
          "answer": 1
        },
        {
          "q": "There aren't ___ apples.",
          "options": [
            "some",
            "any",
            "the"
          ],
          "answer": 1
        }
      ]
    },
    {
      "id": "013",
      "title": "many / much / a lot of",
      "emoji": "💯",
      "category": "形容詞",
      "level": "G7",
      "rule": "many 接可數(many books)。much 接不可數(much water)。a lot of / lots of 兩種都可以(萬用)。否定句和問句多用 many/much,肯定句多用 a lot of。",
      "examples": [
        {
          "en": "I have many books.",
          "zh": "我有很多書。"
        },
        {
          "en": "She drinks a lot of water.",
          "zh": "她喝很多水。"
        },
        {
          "en": "How much money do you have?",
          "zh": "你有多少錢?"
        }
      ],
      "quiz": [
        {
          "q": "There are ___ kids in the park.",
          "options": [
            "many",
            "much",
            "is"
          ],
          "answer": 0
        },
        {
          "q": "I don't have ___ time.",
          "options": [

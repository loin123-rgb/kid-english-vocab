            "is",
            "are"
          ],
          "answer": 1
        }
      ]
    },
    {
      "id": "007",
      "title": "未來式 will / be going to",
      "emoji": "🔮",
      "category": "動詞",
      "level": "G7",
      "rule": "will 用於臨時決定或預測。be going to 用於早就計畫好的事。兩個都接動詞原型(I will go / I am going to go)。",
      "examples": [
        {
          "en": "I will help you.",
          "zh": "我會幫你。(臨時決定)"
        },
        {
          "en": "It will rain tomorrow.",
          "zh": "明天會下雨。(預測)"
        },
        {
          "en": "We are going to visit Japan.",
          "zh": "我們要去日本。(計畫)"
        }
      ],
      "quiz": [
        {
          "q": "I think it ___ snow tonight.",
          "options": [
            "will",
            "is",
            "am"
          ],
          "answer": 0
